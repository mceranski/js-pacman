{
	"name": "pacman-clone",
	"type": "module",
	"devDependencies": {
		"@rollup/plugin-commonjs": "^28.0.1",
		"@rollup/plugin-node-resolve": "^15.3.0",
		"@rollup/plugin-terser": "^0.4.4",
		"gh-pages": "^6.3.0",
		"rollup": "^4.28.1",
		"serve": "^14.2.4"
	},
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w",
		"init-server": "serve public",
		"dev": "start npm run watch && start npm run init-server",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d public" 
	}
}
